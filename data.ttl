@prefix ex: <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix schema: <https://schema.org/> .

ex:me a foaf:Person ;
    foaf:name "Ali" ;
    schema:identifier "1234567" ;
    foaf:mbox "mailto:your.email@example.com" ;
    schema:educationalLevel "Year 2" ;
    schema:knowsAbout "BASH", "TypeScript", "Pyhton" ;
    schema:programMembership "UGhent Course" ;
    foaf:knows ex:studentA, ex:studentB .

ex:studentA a foaf:Person ;
    foaf:name "Student A" .

ex:studentB a foaf:Person ;
    foaf:name "Student B" .
