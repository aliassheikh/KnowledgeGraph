@prefix cv: <http://data.europa.eu/m8g/>.
@prefix person: <http://www.w3.org/ns/person#>.
@prefix locn: <http://www.w3.org/ns/locn#>.
@prefix op-country: <http://publications.europa.eu/resource/authority/country/>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix ldes: <https://w3id.org/ldes#>.
@prefix tree: <https://w3id.org/tree#>.

<http://localhost:3000/ldes> a ldes:EventStream;
  ldes:timestampPath dct:modified;
  ldes:versionOfPath dct:isVersionOf;
  tree:member <https://persons.org/john/v2>, <https://persons.org/john/v3>.

<https://persons.org/john/v2> a person:Person;
  person:birthName "John Doe"@en;
  dct:alternativeName "Johnny Doe"@en;
  cv:domicile [
    a locn:Address;
    locn:fullAddress "Musterstraße 123";
    locn:postName "Berlin"@de
  ];
  person:residency [
    a dct:Jurisdiction;
    dct:identifier op-country:DEU;
    rdfs:label "Germany"@en
  ];
  dct:modified "2013-01-01T00:00:00.000Z"^^xsd:dateTime;
  dct:isVersionOf <https://persons.org/john>.

<https://persons.org/john/v3> a person:Person;
  person:birthName "John Doe"@en;
  dct:alternativeName "Johnny Doe"@en;
  cv:domicile [
    a locn:Address;
    locn:fullAddress "Krijgsgasthuisstraat 86";
    locn:postName "Gent"@nl
  ];
  person:residency [
    a dct:Jurisdiction;
    dct:identifier op-country:BEL;
    rdfs:label "Belgium"@en
  ];
  dct:modified "2017-03-15T00:00:00.000Z"^^xsd:dateTime;
  dct:isVersionOf <https://persons.org/john>.
