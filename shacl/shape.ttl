@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix person: <http://www.w3.org/ns/person#>.
@prefix locn: <http://www.w3.org/ns/locn#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix cv: <http://data.europa.eu/m8g/>.
@prefix ex: <http://example.org/shape/>.
@prefix op-country: <http://publications.europa.eu/resource/authority/country/>.

ex:PersonShape a sh:NodeShape;
  sh:targetClass person:Person;

  # Each person must have exactly one birth name as a language-tagged string
  sh:property [
    sh:path person:birthName;
    sh:minCount 1;
    sh:maxCount 1;
    sh:nodeKind sh:Literal;
    sh:datatype rdf:langString
  ];

  # Each person must have at least one alternative name as a language-tagged string
  sh:property [
    sh:path dct:alternativeName;
    sh:minCount 1;
    sh:nodeKind sh:Literal;
    sh:datatype rdf:langString
  ];

  # Each person must have exactly one domicile that conforms to AddressShape
  sh:property [
    sh:path cv:domicile;
    sh:minCount 1;
    sh:maxCount 1;
    sh:node ex:AddressShape
  ];

  # Each person must have exactly one residency that conforms to JurisdictionShape
  sh:property [
    sh:path person:residency;
    sh:minCount 1;
    sh:maxCount 1;
    sh:node ex:JurisdictionShape
  ];

  # Each person must have exactly one dct:modified value of type xsd:dateTime
  sh:property [
    sh:path dct:modified;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:dateTime
  ];

  # Each person must have exactly one dct:isVersionOf pointing to an IRI
  sh:property [
    sh:path dct:isVersionOf;
    sh:minCount 1;
    sh:maxCount 1;
    sh:nodeKind sh:IRI
  ].

ex:AddressShape a sh:NodeShape;
  sh:targetClass locn:Address;

  sh:property [
    sh:path locn:fullAddress;
    sh:minCount 1;
    sh:maxCount 1;
    sh:nodeKind sh:Literal
    # plain xsd:string or untyped literal allowed for address strings
  ];

  sh:property [
    sh:path locn:postName;
    sh:minCount 1;
    sh:maxCount 1;
    sh:nodeKind sh:Literal;
    sh:datatype rdf:langString
  ].

ex:JurisdictionShape a sh:NodeShape;
  sh:targetClass dct:Jurisdiction;

  sh:property [
    sh:path dct:identifier;
    sh:minCount 1;
    sh:maxCount 1
  ];

  sh:property [
    sh:path rdfs:label;
    sh:minCount 1;
    sh:nodeKind sh:Literal;
    sh:datatype rdf:langString
  ].
